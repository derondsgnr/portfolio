# Supabase (optional — defaults exist for convenience)
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin panel (required for /admin)
ADMIN_SECRET=your-secure-password

# Contact form — email notifications
# Get API key at https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_xxx
CONTACT_EMAIL=your@email.com
# Optional: custom From address (must be verified in Resend; default: onboarding@resend.dev)
# Use an address on your existing verified domain, e.g. hello@yourdomain.com or contact@yourdomain.com
# If you can't add another domain in Resend, use your current domain — Resend lets you send from any address
# on an already-verified domain.
# RESEND_FROM=hello@yourdomain.com

# Supabase — for contact storage (service role = full DB access, server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub API (required for admin content writes)
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO_OWNER=derondsgnr
GITHUB_REPO_NAME=portfolio

# Booking (Calendly or Cal.com — leave empty to hide "Book a call" until ready)
# Calendly: https://calendly.com/your-username/30min
# Cal.com:   https://cal.com/your-username/30min
# NEXT_PUBLIC_BOOKING_URL=

# Integrations (optional overrides — IDs can also be set in admin)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
