[
  {
    "name": "Growth OS - AU01 Post Builder (Success/Warning)",
    "nodes": [
      {
        "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 8 * * *" }] } },
        "id": "au01-schedule",
