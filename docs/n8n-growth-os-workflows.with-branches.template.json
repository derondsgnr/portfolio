        "id": "au01-healthy",
        "name": "Set Healthy Payload",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [980, 340]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://REPLACE_WITH_SUPABASE_PROJECT_ID.supabase.co/functions/v1/make-server-3fa6479f/admin/growth/heartbeat",
          "sendHeaders": true,
          "headerParameters": { "parameters": [{ "name": "Authorization", "value": "Bearer REPLACE_WITH_SUPABASE_ANON_KEY" }, { "name": "Content-Type", "value": "application/json" }] },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{$json}}"
        },
        "id": "au01-post",
        "name": "POST Heartbeat",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [1240, 260]
      }
    ],
    "connections": {
      "Schedule Trigger": { "main": [[{ "node": "Set Metrics (Replace from real nodes)", "type": "main", "index": 0 }]] },
      "Set Metrics (Replace from real nodes)": { "main": [[{ "node": "If Failed Count > 0", "type": "main", "index": 0 }]] },
