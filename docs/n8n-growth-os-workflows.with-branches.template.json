        "typeVersion": 2,
        "position": [720, 260]
      },
      {
        "parameters": { "assignments": { "assignments": [{ "name": "automationId", "value": "au-01", "type": "string" }, { "name": "health", "value": "warning", "type": "string" }, { "name": "throughput", "value": "={{\"run failed: \" + ($json.failedCount || 1) + \" error(s)\"}}", "type": "string" }, { "name": "lastRun", "value": "={{$now}}", "type": "string" }] } },
        "id": "au01-warning",
        "name": "Set Warning Payload",
