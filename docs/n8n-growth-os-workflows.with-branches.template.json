        "id": "au01-metrics",
        "name": "Set Metrics (Replace from real nodes)",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [470, 260]
      },
      {
        "parameters": { "conditions": { "number": [{ "value1": "={{$json.failedCount || 0}}", "operation": "larger", "value2": 0 }] } },
        "id": "au01-if",
        "name": "If Failed Count > 0",
